# Railway Environment Variables
# Copy this to Railway dashboard > Variables

# Server
PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/zetatube?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# Client (optional - for production builds)
VITE_API_URL=